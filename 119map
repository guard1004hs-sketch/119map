<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>행사장 AR 길찾기</title>
    <!-- 오픈소스 AR 라이브러리 불러오기 -->
    <script src="https://aframe.io/releases/1.3.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar-nft.js"></script>
  </head>

  <body style="margin: 0; overflow: hidden;">
    <!-- AR 화면 설정 -->
    <a-scene vr-mode-ui="enabled: false" embedded arjs="sourceType: webcam; debugUIEnabled: false;">
      
      <!-- 스마트폰 카메라 및 GPS 연동 -->
      <a-camera gps-camera rotation-reader></a-camera>

      <!-- 🔴 빨간색 3D 화살표 이정표 (목적지 설정) -->
      <!-- ⚠️ 아래 latitude(위도)와 longitude(경도)에 실제 행사장 좌표를 입력하세요 -->
      <a-entity
        gltf-model="url(https://raw.githubusercontent.com/KhronosGroup/glTF-Sample-Models/master/2.0/Arrow/glTF/Arrow.gltf)"
        gps-entity-place="latitude: 37.10289738539689; longitude: 129.04241141773647;"
        scale="10 10 10"
        look-at="[gps-camera]"
      ></a-entity>

    </a-scene>
  </body>
</html>
